# ─────────────────────────────────────────────
#  Discord Music Bot — Environment Configuration
# ─────────────────────────────────────────────

# Discord Bot Token (required)
# Get yours at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application / Client ID (required)
# Found on your app's "General Information" page
CLIENT_ID=your_client_id_here

# Spotify Credentials (optional — needed for Spotify links)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Web Dashboard
DASHBOARD_PORT=3000
DASHBOARD_SECRET=change_this_to_a_random_secret
